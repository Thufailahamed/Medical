# Set to "true" to bypass Supabase authentication (dev only)
EXPO_PUBLIC_DEV_MODE=true

# API URL
EXPO_PUBLIC_API_URL=http://localhost:8787

# Phase 1.3: WhatsApp onboarding. Digits only, no "+" or "wa.me/" prefix.
# Example: "94771234567" for +94 77 123 4567. Leave empty to hide the
# "Continue with WhatsApp" button from the login screen.
EXPO_PUBLIC_WA_PHONE=

# Supabase (only needed when DEV_MODE=false)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
