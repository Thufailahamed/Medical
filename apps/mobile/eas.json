{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {}
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "${env.ASC_APP_ID}",
        "appleTeamId": "${env.APPLE_TEAM_ID}"
      },
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "${env.GOOGLE_SERVICE_ACCOUNT_KEY_PATH}"
      }
    },
    "preview": {
      "ios": {
        "simulator": true
      },
      "android": {
        "track": "internal"
      }
    }
  }
}