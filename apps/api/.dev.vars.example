# Set to "true" to bypass Supabase authentication (dev only)
DEV_MODE=true
# Optional: enable dev auto-seed login without full DEV_MODE (Cloudflare demo)
ALLOW_DEV_SEED=true

# Supabase (only needed when DEV_MODE=false)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Phase E-Rx 6: 32-byte base64 key encryption key for doctor signing
# private keys. Generate with: openssl rand -base64 32
# In prod set via: wrangler secret put DOCTOR_KEY_KEK
DOCTOR_KEY_KEK=replace-me-openssl-rand-base64-32

# Phase 4: SMS OTP (SMSLenz)
SMS_PROVIDER=console
SMSLENZ_USER_ID=1958
SMSLENZ_API_KEY=your-smslenz-api-key
SMS_SENDER_ID=SMSlenzDEMO

# Video consultation — WebRTC ICE servers.
# Without TURN, ~12% of mobile and corporate networks (symmetric NAT)
# cannot establish a peer-to-peer media path. For dev we fall back to
# Google STUN-only, which works on most home networks. In prod set:
#   wrangler secret put TURN_URLS '["turn:turn.example.com:3478"]'
#   wrangler secret put TURN_USERNAME "..."
#   wrangler secret put TURN_CREDENTIAL "..."
# TURN_URLS is a JSON-encoded array of "turn:host:port" strings.
TURN_URLS="[]"
TURN_USERNAME=""
TURN_CREDENTIAL=""
